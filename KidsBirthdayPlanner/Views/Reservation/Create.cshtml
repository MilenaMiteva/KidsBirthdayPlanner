@model KidsBirthdayPlanner.ViewModels.ReservationViewModel

@{
    ViewData["Title"] = "Create Reservation";
}

<h2>Create Reservation</h2>

<h4 class="mb-3">Party: @Model.PartyName</h4>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <input type="hidden" asp-for="BirthdayPartyId" />

    <div class="form-group mb-3">
        <label asp-for="ChildrenCount"></label>
        <input asp-for="ChildrenCount" class="form-control" />
        <span asp-validation-for="ChildrenCount" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Notes"></label>
        <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">
        Reserve
    </button>

    <a asp-controller="BirthdayParty"
       asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}