@using KidsBirthdayPlanner.ViewModels
@model BirthdayPartyListViewModel

<h2 class="text-center mb-4">Birthday Parties</h2>
<form method="get" class="mb-4 text-center">

    <input type="text"
           name="searchTerm"
           value="@Model.SearchTerm"
           placeholder="Search by theme or location..."
           class="form-control w-50 d-inline" />

    <button type="submit" class="btn btn-primary ms-2">
        Search
    </button>

    <a asp-action="Index" class="btn btn-secondary ms-2">
        Reset
    </a>

</form>

<div class="text-center mb-4">
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-success">
            + Create Birthday Party
        </a>
    }
</div>

@if (!Model.Parties.Any())
{
    <div class="col-12">
        <p class="text-center">
            No birthday parties found. Create one to get started!
        </p>
    </div>
}
else
{
    <div class="row">
        @foreach (var party in Model.Parties)
        {
            <partial name="_BirthdayPartyCardPartial" model="party" />
        }
    </div>
}
@if (Model.TotalPages > 1)
{
    <div class="text-center mt-4">
        @if (Model.CurrentPage > 1)
        {
            <a asp-action="Index"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-page="@(Model.CurrentPage - 1)"
               class="btn btn-outline-primary me-2">
                Previous
            </a>
        }

        <span class="fw-bold">Page @Model.CurrentPage of @Model.TotalPages</span>

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a asp-action="Index"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-page="@(Model.CurrentPage + 1)"
               class="btn btn-outline-primary ms-2">
                Next
            </a>
        }
    </div>
}