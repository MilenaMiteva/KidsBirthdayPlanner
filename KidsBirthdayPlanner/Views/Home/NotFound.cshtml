@{
    ViewData["Title"] = "Page Not Found";
}

<div class="container text-center mt-5">
    <h1 class="display-4 text-light">404</h1>
    <h2 class="text-light">Oops! Page not found.</h2>
    <p class="text-light">The page you are looking for does not exist.</p>

    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light mt-3">
        Back to Home
    </a>
</div>