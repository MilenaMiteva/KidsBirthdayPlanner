@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container text-center mt-5">
    <h1 class="display-4 text-light">500</h1>
    <h2 class="text-light">Something went wrong.</h2>
    <p class="text-light">An unexpected error occurred while processing your request.</p>

    @if (Model?.RequestId != null)
    {
        <p class="text-light">
            <strong>Request ID:</strong> @Model.RequestId
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light mt-3">
        Back to Home
    </a>
</div>